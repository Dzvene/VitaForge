# ---- Application ----
APP_NAME=VitaForge
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ---- Server ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
# Include the admin origin in production, e.g.
#   https://vitaforge.matrix-capital.net,https://admin-vitaforge.matrix-capital.net
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:3001

# ---- Database (asyncpg) ----
DATABASE_URL=postgresql+asyncpg://vitaforge:vitaforge@localhost:5432/vitaforge

# ---- Security (CHANGE THESE) ----
SECRET_KEY=change-me-to-a-random-32+-char-string
JWT_SECRET=change-me-to-another-random-32+-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Email (password reset + verification) ----
# Leave SMTP_HOST/SMTP_PASSWORD empty in dev — mail is logged to the console
# (with the link) instead of sent, so the flows are fully testable without SMTP.
FRONTEND_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@vitaforge.app
SMTP_FROM_NAME=VitaForge
SMTP_USE_SSL=true

# ---- Food data dumps (for the import script, spec §7) ----
OFF_DUMP_PATH=
USDA_DUMP_PATH=
