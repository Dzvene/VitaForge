# ---- Application ----
APP_NAME=Baseline
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ---- Server ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ---- Database (asyncpg) ----
DATABASE_URL=postgresql+asyncpg://baseline:baseline@localhost:5432/baseline

# ---- Security (CHANGE THESE) ----
SECRET_KEY=change-me-to-a-random-32+-char-string
JWT_SECRET=change-me-to-another-random-32+-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Food data dumps (for the import script, spec §7) ----
OFF_DUMP_PATH=
USDA_DUMP_PATH=
