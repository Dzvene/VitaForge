<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns the real theming (ui/theme/Theme.kt). This framework theme
         is only the activity host: a no-action-bar light shell. -->
    <style name="Theme.VitaForge" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
